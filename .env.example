# --- OpenRouter (used for actual model calls) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://agora.local
OPENROUTER_APP_TITLE=Agora

# --- Specter API ---
SPECTER_API_KEY=
SPECTER_BASE_URL=https://app.tryspecter.com/api/v1
SPECTER_TIMEOUT_SECONDS=8.0

# --- Risk-aware model routing ---
MODEL_LOW_RISK=openai/gpt-4o-mini
MODEL_MEDIUM_RISK=openai/gpt-4o
MODEL_HIGH_RISK=anthropic/claude-sonnet-4.6
MODEL_VERDICT_DEFAULT=anthropic/claude-sonnet-4.6
MODEL_VERDICT_HIGH_RISK=anthropic/claude-sonnet-4.6

# Risk amount thresholds (in transaction currency units)
RISK_AMOUNT_MEDIUM_THRESHOLD=5000
RISK_AMOUNT_HIGH_THRESHOLD=20000

# --- Debate behavior ---
DEBATE_MAX_ROUNDS=6

# --- CORS for local dev ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
